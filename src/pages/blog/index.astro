---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const POSTS_PER_PAGE = 12;
const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
const currentPage = 1;
const pagePosts = posts.slice(0, POSTS_PER_PAGE);
const featuredPost = pagePosts[0];
const gridPosts = pagePosts.slice(1);

function excerpt(body: string, length = 160): string {
  const text = body
    .replace(/^#+\s+.*/gm, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_`#>]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
  return text.length > length ? text.slice(0, length).replace(/\s+\S*$/, '') + '…' : text;
}

function readingTime(body: string): number {
  const words = body.replace(/[^a-zA-Z\s]/g, ' ').split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---
<Layout title="Writing — Robertson Price" description="Notes on AI, building companies, and what happens at the frontier.">
<style>
  .blog-page {
    padding-top: calc(80px + var(--section-gap));
    padding-bottom: var(--section-gap);
  }
  .blog-header {
    max-width: 720px;
    margin-bottom: clamp(48px, 6vw, 80px);
  }
  .blog-header h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }
  .archive-intro {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    max-width: 600px;
  }

  /* ---- FEATURED POST ---- */
  .featured-post {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(24px, 4vw, 48px);
    align-items: center;
    margin-bottom: clamp(48px, 6vw, 80px);
    padding-bottom: clamp(48px, 6vw, 80px);
    border-bottom: 1px solid var(--color-border-light);
    text-decoration: none;
    color: inherit;
  }
  .featured-post:hover .featured-title { opacity: 0.7; }
  .featured-image {
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-border-light);
  }
  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .featured-post:hover .featured-image img { transform: scale(1.02); }
  .featured-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: 16px;
  }
  .featured-title {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    transition: opacity 0.2s ease;
  }
  .featured-excerpt {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 20px;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
  }
  .post-meta .sep { opacity: 0.4; }

  /* ---- POST GRID ---- */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(24px, 3vw, 40px);
    margin-bottom: clamp(48px, 6vw, 80px);
  }
  .post-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }
  .post-card:hover .card-title { opacity: 0.7; }
  .card-image {
    aspect-ratio: 16 / 9;
    border-radius: 6px;
    overflow: hidden;
    background: var(--color-border-light);
    margin-bottom: 20px;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .post-card:hover .card-image img { transform: scale(1.03); }
  .card-title {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
    transition: opacity 0.2s ease;
  }
  .card-excerpt {
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin-bottom: 16px;
    flex: 1;
  }

  /* ---- PAGINATION ---- */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding-top: clamp(32px, 4vw, 48px);
    border-top: 1px solid var(--color-border-light);
  }
  .page-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 6px;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all 0.2s ease;
    border: 1px solid transparent;
  }
  .page-btn:hover { color: var(--color-text); border-color: var(--color-border); }
  .page-btn.active { color: var(--color-text); border-color: var(--color-border); background: var(--color-surface); }
  .page-btn.nav-btn { width: auto; padding: 0 16px; gap: 8px; font-size: 0.82rem; }
  .page-btn.nav-btn svg { width: 14px; height: 14px; }

  @media (max-width: 900px) {
    .post-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .featured-post { grid-template-columns: 1fr; }
    .post-grid { grid-template-columns: 1fr; }
  }
</style>
<div class="blog-page">
  <div class="container">
    <div class="blog-header">
      <h1>Writing</h1>
      <p class="archive-intro">Since 2021, I've shared real-time analysis and commentary on crypto markets and artificial intelligence with a private community of several hundred people. These posts are adapted from that running commentary — first-draft thinking shared in the moment.</p>
    </div>

    {featuredPost && (
      <a href={`/blog/${featuredPost.id}`} class="featured-post">
        <div class="featured-image">
          <img src={`/images/blog/${featuredPost.id}.svg`} alt={featuredPost.data.title} loading="eager" />
        </div>
        <div class="featured-content">
          <p class="featured-label">Latest</p>
          <h2 class="featured-title">{featuredPost.data.title}</h2>
          <p class="featured-excerpt">{excerpt(featuredPost.body || '', 200)}</p>
          <div class="post-meta">
            <span>{formatDate(featuredPost.data.date)}</span>
            <span class="sep">·</span>
            <span>{readingTime(featuredPost.body || '')} min read</span>
          </div>
        </div>
      </a>
    )}

    <div class="post-grid">
      {gridPosts.map(post => (
        <a href={`/blog/${post.id}`} class="post-card">
          <div class="card-image">
            <img src={`/images/blog/${post.id}.svg`} alt={post.data.title} loading="lazy" />
          </div>
          <h2 class="card-title">{post.data.title}</h2>
          <p class="card-excerpt">{excerpt(post.body || '')}</p>
          <div class="post-meta">
            <span>{formatDate(post.data.date)}</span>
            <span class="sep">·</span>
            <span>{readingTime(post.body || '')} min read</span>
          </div>
        </a>
      ))}
    </div>

    <nav class="pagination" aria-label="Pagination">
      <span class="page-btn active">1</span>
      {Array.from({ length: Math.min(totalPages - 1, 6) }, (_, i) => i + 2).map(p => (
        <a href={`/blog/page/${p}`} class="page-btn">{p}</a>
      ))}
      {totalPages > 7 && <span class="page-btn" style="border:none">…</span>}
      {totalPages > 7 && <a href={`/blog/page/${totalPages}`} class="page-btn">{totalPages}</a>}
      <a href="/blog/page/2" class="page-btn nav-btn">
        Next
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>
    </nav>
  </div>
</div>
</Layout>
